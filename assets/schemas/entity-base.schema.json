{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yourusername/systems-catalog/schemas/entity-base.schema.json",
  "title": "Base Entity Schema",
  "description": "Common properties shared by all entity types",
  "type": "object",
  "required": ["id", "name", "systemType"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique entity identifier"
    },
    "name": {
      "type": "string",
      "description": "Entity display name"
    },
    "description": {
      "type": "string",
      "description": "Entity description or purpose",
      "default": ""
    },
    "systemType": {
      "type": "string",
      "description": "Entity type discriminator",
      "enum": ["service", "api", "database", "zone", "step_processor"]
    },
    "parentId": {
      "type": ["integer", "null"],
      "description": "ID of parent entity for hierarchical relationships"
    },
    "calculatedName": {
      "type": "string",
      "description": "Computed hierarchical name path",
      "default": ""
    },
    "mapX": {
      "type": ["number", "null"],
      "description": "Deprecated: X position (use project.json instead)"
    },
    "mapY": {
      "type": ["number", "null"],
      "description": "Deprecated: Y position (use project.json instead)"
    },
    "lineColorOverride": {
      "type": ["string", "null"],
      "description": "Custom color for entity connections (hex or CSS color)"
    },
    "namingRoot": {
      "type": "boolean",
      "description": "Whether this entity is a naming hierarchy root",
      "default": false
    },
    "namingDelimiter": {
      "type": "string",
      "description": "Delimiter for hierarchical name construction",
      "default": "/"
    },
    "techIds": {
      "type": "array",
      "description": "Technology stack references",
      "items": {
        "type": "integer"
      },
      "default": []
    },
    "notes": {
      "type": "array",
      "description": "Entity notes/comments",
      "items": {
        "$ref": "#/definitions/Note"
      },
      "default": []
    }
  },
  "definitions": {
    "Note": {
      "type": "object",
      "required": ["id", "body", "updatedAt"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "Note identifier"
        },
        "body": {
          "type": "string",
          "description": "Note content"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO 8601 timestamp of last update",
          "format": "date-time"
        }
      }
    }
  }
}
